---
import '../styles/global.css';

const whatsappText = 'Olá, vim pelo site do Studio Privé Copacabana e quero saber horários disponíveis.';
const whatsappUrl = `https://wa.me/5521985789896?text=${encodeURIComponent(whatsappText)}`;
const addressText = 'Rua Siqueira Campos, 30, Copacabana, Rio de Janeiro';
const addressQuery = encodeURIComponent(addressText);
const googleMapsUrl = `https://www.google.com/maps/search/?api=1&query=${addressQuery}`;
const googleMapsEmbedUrl = `https://www.google.com/maps?q=${addressQuery}&output=embed`;
const wazeUrl = 'https://waze.com/ul?ll=-22.9688295,-43.1846804&q=Rua%20Siqueira%20Campos,%2030&navigate=yes';
const uberUrl = `https://m.uber.com/ul/?action=setPickup&dropoff[formatted_address]=${addressQuery}`;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const experiences = [
  {
    title: 'Massagem relaxante',
    text: 'Toque envolvente para aliviar tensões, desacelerar e deixar o corpo mais leve.',
  },
  {
    title: 'Massagem tântrica',
    text: 'Experiência sensorial com presença, respiração e condução cuidadosa do toque.',
  },
  {
    title: 'Esfoliação corporal',
    text: 'Cuidado para renovar a pele e preparar o corpo para uma sensação mais suave.',
  },
  {
    title: 'Depilação masculina',
    text: 'Atendimento reservado para cuidado corporal com higiene, discrição e conforto.',
  },
];

const galleryItems = [
  { src: `${baseUrl}gallery/alex-01.png`, alt: 'Foto de Alex em estilo editorial 1' },
  { src: `${baseUrl}gallery/alex-02.png`, alt: 'Foto de Alex em estilo editorial 2' },
  { src: `${baseUrl}gallery/alex-03.png`, alt: 'Foto de Alex em estilo editorial 3' },
  { src: `${baseUrl}gallery/alex-04.png`, alt: 'Foto de Alex em estilo editorial 4' },
  { src: `${baseUrl}gallery/alex-05.png`, alt: 'Foto de Alex em estilo editorial 5' },
  { src: `${baseUrl}gallery/alex-06.png`, alt: 'Foto de Alex em estilo editorial 6' },
  { src: `${baseUrl}gallery/alex-07.png`, alt: 'Foto de Alex em estilo editorial 7' },
  { src: `${baseUrl}gallery/alex-08.png`, alt: 'Foto de Alex em estilo editorial 8' },
  { src: `${baseUrl}gallery/alex-09.png`, alt: 'Foto de Alex em estilo editorial 9' },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Studio Privé Copacabana, experiências sensoriais em espaço privativo na Rua Siqueira Campos." />
    <meta name="robots" content="index, follow" />
    <title>Studio Privé Copacabana</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="age-gate" data-age-gate aria-modal="true" role="dialog" aria-labelledby="age-title">
      <div class="age-card">
        <p class="eyebrow">Conteúdo adulto discreto</p>
        <h1 id="age-title">Você tem <span class="age-number">18</span> anos ou mais?</h1>
        <p>Este site apresenta experiências sensoriais para visitantes maiores de idade.</p>
        <div class="age-actions">
          <button class="button button-primary" type="button" data-age-enter>Sou maior de 18 anos</button>
          <a class="button button-ghost" href="https://www.google.com/">Sair</a>
        </div>
      </div>
    </div>

    <header class="site-header" aria-label="Navegação principal">
      <a class="brand" href="#top" aria-label="Studio Privé Copacabana">Studio Privé Copacabana</a>
      <nav>
        <a href="#experiencias">Experiências</a>
        <a href="#discricao">Discrição</a>
        <a href="#localizacao">Localização</a>
        <a class="nav-cta" href={whatsappUrl} target="_blank" rel="noreferrer">Agendar</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero section-shell" data-hero>
        <div class="hero-copy reveal">
          <p class="eyebrow">Copacabana, Rio de Janeiro</p>
          <h1>Studio Privé Copacabana</h1>
          <p class="hero-lead">Um espaço reservado para relaxar, sentir e viver uma experiência corporal com discrição no coração de Copacabana.</p>
          <p class="hero-location">Atendimento privativo na Rua Siqueira Campos, 30.</p>
          <div class="hero-actions">
            <a class="button button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">Agendar atendimento</a>
          </div>
        </div>
        <div class="hero-art reveal" aria-hidden="true">
          <div class="orb orb-one"></div>
          <div class="orb orb-two"></div>
          <div class="hero-panel">
            <span>Privé</span>
            <strong>luz baixa, presença e reserva</strong>
          </div>
        </div>
      </section>

      <section class="section-shell gallery-section" id="galeria">
        <div class="section-heading reveal">
          <p class="eyebrow">Galeria</p>
          <h2>Presença e estilo</h2>
          <p>Conheça o Alex César</p>
        </div>
        <div class="gallery-grid" aria-label="Galeria pública com nove imagens">
          {galleryItems.map((item, index) => (
            <button class="gallery-item reveal" type="button" data-gallery-item data-gallery-src={item.src} data-gallery-alt={item.alt} aria-label={`Ampliar ${item.alt}`} style={`--delay:${index * 45}ms`}>
              <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
            </button>
          ))}
        </div>
      </section>

      <section class="section-shell experiences" id="experiencias">
        <div class="section-heading reveal">
          <p class="eyebrow">Experiências</p>
          <h2>Escolha o cuidado que combina com seu momento</h2>
          <p>Cada atendimento é conduzido com privacidade, presença e atenção ao ritmo do corpo.</p>
        </div>
        <div class="experience-grid">
          {experiences.map((experience, index) => (
            <article class="experience-card reveal" style={`--delay:${index * 80}ms`}>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{experience.title}</h3>
              <p>{experience.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-shell privacy-band" id="discricao">
        <div class="privacy-copy reveal">
          <p class="eyebrow">Discrição e segurança</p>
          <h2>Discrição do primeiro contato ao atendimento</h2>
          <p>O agendamento começa pelo WhatsApp, com conversa direta para consultar horários e alinhar detalhes. O endereço público fica em Copacabana; informações complementares são passadas apenas após o contato inicial.</p>
        </div>
        <div class="privacy-list reveal">
          <span>Atendimento privativo</span>
          <span>Local reservado</span>
          <span>Conversa inicial pelo WhatsApp</span>
          <span>Sem exposição desnecessária</span>
        </div>
      </section>

      <section class="section-shell ambience">
        <div class="ambience-card reveal">
          <p class="eyebrow">Ambiente</p>
          <h2>Um ambiente reservado para o seu momento</h2>
          <p>Luz baixa, atmosfera quente e cuidado nos detalhes para criar uma experiência íntima, confortável e discreta.</p>
        </div>
      </section>

      <section class="section-shell location" id="localizacao">
        <div class="location-copy reveal">
          <p class="eyebrow">Localização</p>
          <h2>No coração de Copacabana</h2>
          <p>Atendimento em endereço de fácil acesso, próximo ao movimento da Siqueira Campos, com chegada simples e discreta.</p>
        </div>
        <div class="map-card reveal">
          <div class="map-frame">
            <iframe
              title="Mapa do Studio Privé Copacabana"
              src={googleMapsEmbedUrl}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              aria-hidden="true"
            ></iframe>
            <a class="map-open-overlay" href={googleMapsUrl} target="_blank" rel="noreferrer" aria-label="Abrir endereço no Google Maps"></a>
          </div>
          <address class="map-address">
            <span>Rua Siqueira Campos, 30</span>
            <strong>Copacabana</strong>
          </address>
          <div class="route-actions" aria-label="Abrir rota em aplicativo">
            <a href={googleMapsUrl} target="_blank" rel="noreferrer">Google Maps</a>
            <a href={wazeUrl} target="_blank" rel="noreferrer">Waze</a>
            <a href={uberUrl} target="_blank" rel="noreferrer">Uber</a>
          </div>
        </div>
      </section>

      <section class="final-cta section-shell reveal" data-final-cta>
        <p class="eyebrow">Contato</p>
        <h2>Reserve seu momento com discrição</h2>
        <p>Envie uma mensagem para consultar disponibilidade e combinar os detalhes com discrição.</p>
        <a class="button button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">Agendar atendimento</a>
      </section>
    </main>

    <a class="floating-cta" href={whatsappUrl} target="_blank" rel="noreferrer" aria-label="Agendar atendimento pelo WhatsApp" data-floating-cta>
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M12.04 2C6.5 2 2 6.42 2 11.88c0 1.74.47 3.45 1.35 4.95L2 22l5.34-1.39a10.08 10.08 0 0 0 4.7 1.17h.01c5.54 0 10.05-4.42 10.05-9.88C22.1 6.42 17.58 2 12.04 2Zm0 18.1h-.01a8.36 8.36 0 0 1-4.25-1.15l-.3-.18-3.17.83.85-3.08-.2-.31a8.12 8.12 0 0 1-1.28-4.33c0-4.52 3.75-8.2 8.37-8.2 4.62 0 8.37 3.68 8.37 8.2s-3.75 8.22-8.37 8.22Zm4.59-6.27c-.25-.12-1.5-.73-1.74-.8-.23-.1-.4-.12-.56.12-.17.24-.65.8-.8.96-.15.17-.3.2-.56.07a6.87 6.87 0 0 1-2.02-1.24 7.46 7.46 0 0 1-1.4-1.72c-.15-.24-.02-.37.1-.5.1-.1.24-.25.36-.37.12-.14.17-.24.25-.4.08-.17.04-.31-.02-.44-.06-.12-.56-1.33-.76-1.82-.2-.48-.41-.42-.56-.43h-.48c-.16 0-.43.06-.65.3s-.86.84-.86 2.05.88 2.39 1 2.56c.12.16 1.7 2.68 4.13 3.75.57.24 1 .38 1.35.49.57.18 1.1.16 1.52.1.46-.07 1.5-.61 1.71-1.2.2-.6.2-1.1.14-1.2-.06-.11-.22-.17-.47-.29Z"/>
      </svg>
    </a>

      <div class="lightbox" data-lightbox aria-hidden="true" role="dialog" aria-label="Imagem ampliada da galeria">
        <button type="button" class="lightbox-close" data-lightbox-close aria-label="Fechar imagem">×</button>
        <div class="lightbox-image">
          <img data-lightbox-image src="" alt="" />
        </div>
      </div>

    <script>
      const gate = document.querySelector('[data-age-gate]');
      const enterButton = document.querySelector('[data-age-enter]');
      const ageAccepted = localStorage.getItem('studio-prive-age-ok');

      if (ageAccepted === 'true') {
        gate?.classList.add('is-hidden');
      }

      enterButton?.addEventListener('click', () => {
        localStorage.setItem('studio-prive-age-ok', 'true');
        gate?.classList.add('is-hidden');
      });

      const revealItems = document.querySelectorAll('.reveal');
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.16 });

      revealItems.forEach((item) => revealObserver.observe(item));

      const hero = document.querySelector('[data-hero]');
      const finalCta = document.querySelector('[data-final-cta]');
      const floatingCta = document.querySelector('[data-floating-cta]');

      const toggleFloatingCta = () => {
        if (!hero || !floatingCta) return;
        const heroBottom = hero.getBoundingClientRect().bottom;
        const heroFinished = heroBottom <= window.innerHeight * 0.18;
        const finalCtaVisible = finalCta ? finalCta.getBoundingClientRect().top <= window.innerHeight * 0.92 : false;
        floatingCta.classList.toggle('is-visible', heroFinished && !finalCtaVisible);
      };

      toggleFloatingCta();
      window.addEventListener('scroll', toggleFloatingCta, { passive: true });
      window.addEventListener('resize', toggleFloatingCta);

      const lightbox = document.querySelector('[data-lightbox]');
      const lightboxImage = document.querySelector('[data-lightbox-image]');
      const closeLightbox = document.querySelector('[data-lightbox-close]');

      document.querySelectorAll('[data-gallery-item]').forEach((item, index) => {
        item.addEventListener('click', () => {
          if (lightboxImage instanceof HTMLImageElement) {
            lightboxImage.src = item.getAttribute('data-gallery-src') || '';
            lightboxImage.alt = item.getAttribute('data-gallery-alt') || '';
          }
          lightbox?.classList.add('is-open');
          lightbox?.setAttribute('aria-hidden', 'false');
        });
      });

      const close = () => {
        lightbox?.classList.remove('is-open');
        lightbox?.setAttribute('aria-hidden', 'true');
      };

      closeLightbox?.addEventListener('click', close);
      lightbox?.addEventListener('click', (event) => {
        if (event.target === lightbox) close();
      });
      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') close();
      });
    </script>
  </body>
</html>
